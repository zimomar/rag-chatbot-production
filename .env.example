# =============================================================================
# RAG Local - Configuration Environment
# =============================================================================
# Copiez ce fichier vers .env et adaptez les valeurs

# -----------------------------------------------------------------------------
# Ollama Configuration
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=mistral:7b-instruct-v0.3-q4_K_M
OLLAMA_EMBED_MODEL=nomic-embed-text

# -----------------------------------------------------------------------------
# ChromaDB Configuration
# -----------------------------------------------------------------------------
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=rag_documents

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# -----------------------------------------------------------------------------
# Streamlit Configuration
# -----------------------------------------------------------------------------
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# -----------------------------------------------------------------------------
# Document Processing
# -----------------------------------------------------------------------------
# Taille des chunks en caractères
CHUNK_SIZE=1000
# Chevauchement entre chunks en caractères
CHUNK_OVERLAP=200
# Nombre de documents à récupérer pour le contexte
RETRIEVAL_TOP_K=4

# -----------------------------------------------------------------------------
# Authentication (optionnel)
# -----------------------------------------------------------------------------
# Mot de passe pour l'interface Streamlit (laisser vide = pas d'auth)
APP_PASSWORD=
# Clé API pour protéger les endpoints FastAPI (laisser vide = pas d'auth)
APP_API_KEY=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
